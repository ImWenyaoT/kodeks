# Kodeks 环境变量示例（只放变量名 + 占位说明，绝不放真值）。
# 架构：Next.js React 前端（:3000）+ Python FastAPI 后端（:8000，uvicorn）双进程。
# 前端经 next.config.ts 的 rewrites 把 /api/* 反代到 Python，浏览器全程同源。

# ── 模型 / 上游（必填）────────────────────────────────────────────────
# DeepSeek（OpenAI 兼容）API key 与 base URL；聊天/工具往返的上游。
# 这些名字经 config.py 的 MODEL_ENV_ALIASES 映射到 KODEKS_CHAT_COMPLETIONS_*。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 可选：覆盖默认模型名（不填用代码内默认）。
DEEPSEEK_MODEL=

# ── 前端 → 后端代理（前端进程读取）──────────────────────────────────
# next.config.ts 据此把 /api/* 反代到 Python 后端。
# 本地缺省即可；生产指向独立部署的 Python 服务（如 https://api.example.com）。
KODEKS_API_ORIGIN=http://127.0.0.1:8000

# ── Python 后端可选项（不填用代码内默认）───────────────────────────────
# 本地 SQLite 路径；缺省 <workspace>/.kodeks/kodeks.sqlite3。
KODEKS_DB_PATH=
# 授权工作区根；缺省进程 cwd。
KODEKS_WORKSPACE_ROOT=
# 跨源浏览器调用白名单（逗号分隔）。同源 rewrites 架构下无需设置，留空即可。
KODEKS_CORS_ORIGINS=
