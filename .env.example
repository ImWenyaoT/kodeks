# Kodeks 环境变量示例（只放变量名 + 占位说明，绝不放真值）。
# 本地开发：只需 DEEPSEEK_* 段；其余云端段留空即可（默认全 local 后端）。
# Vercel 生产：见 docs/DEPLOY.md 的 runbook，按需配置云端段。

# ── 模型 / 上游（必填，本地与线上都需要）─────────────────────────────
# DeepSeek（OpenAI 兼容）API key 与 base URL；聊天/工具往返的上游。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 可选：覆盖默认模型名（不填用代码内默认）。
DEEPSEEK_MODEL=

# ── Turso / libSQL 持久化（线上必填；本地留空 → 走本地 file: SQLite）──────
# Turso 数据库 URL（libsql://<db>-<org>.turso.io）。留空则用本地 file: SQLite（KODEKS_DB_PATH 或 workspace/.kodeks/kodeks.sqlite3）。
TURSO_DATABASE_URL=
# Turso 鉴权 token。仅连远端（libsql://）时需要；本地 file: 无需。
TURSO_AUTH_TOKEN=

# ── Vercel Blob artifact 存储（线上必填；本地留空 → 走本地文件 artifact）──
# Vercel Blob 读写 token。置位 → 内存 artifact 存进 Blob；留空 → 本地 .kodeks/memory-artifacts。
BLOB_READ_WRITE_TOKEN=

# ── 控制面 API 保护（线上必填；本地 localhost 可留空）─────────────────
# 非本地 /api/* 请求必须带 Authorization: Bearer、x-kodeks-control-token 或 kodeks_control_token cookie。
KODEKS_CONTROL_TOKEN=

# ── Vercel Sandbox 命令执行（线上审批执行用；Vercel 缺鉴权 → fail closed）─
# 在 Vercel 上运行时由平台自动注入，无需手填：
#   VERCEL                 部署在 Vercel 时平台自动置位（=1）。
#   VERCEL_OIDC_TOKEN      OIDC 鉴权 token，Vercel 线上自动注入；本地用 `vercel env pull` 拉取。
# 仅当在非 Vercel 环境（外部 CI/自托管）用 Sandbox 时，改用 access token 三件套：
#   VERCEL_TOKEN           Vercel 个人/团队 access token。
#   VERCEL_TEAM_ID         团队 ID（team_xxx）。
#   VERCEL_PROJECT_ID      项目 ID（prj_xxx）。
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=
